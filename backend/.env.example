# ============================================
# VideoCatcher 环境变量配置（示例）
# 复制此文件为 .env 并填入真实值
# ============================================

# ── AI 服务（支持 DeepSeek / Claude）──
# DeepSeek → https://platform.deepseek.com 获取（sk-xxx）
# Claude   → https://console.anthropic.com 获取（sk-ant-xxx）
AI_API_KEY=your-api-key-here

# AI_PROVIDER: auto / deepseek / claude
AI_PROVIDER=auto

# AI_MODEL: 留空使用默认
# DeepSeek 默认: deepseek-chat  |  Claude 默认: claude-sonnet-4-20250514
# AI_MODEL=

# ── 服务器配置 ──
CORS_ORIGINS=*

# ── 缓存时间（秒）──
VIDEO_INFO_CACHE_TTL=1800
SUMMARY_CACHE_TTL=3600

# ── 临时下载目录 ──
TEMP_DOWNLOAD_DIR=./downloads

# ── Bilibili Cookie（解锁 1080p+ 高清下载）──
# 未登录 Bilibili 限 480p
# 获取方式: 浏览器登录 → F12 → Application → Cookies → SESSDATA
BILIBILI_COOKIE=your-bilibili-cookie-here
